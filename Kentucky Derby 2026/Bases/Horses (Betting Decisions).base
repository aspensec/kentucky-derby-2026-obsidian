filters:
  and:
    - file.folder == "Horse Racing/Kentucky Derby 2026/Horses"
properties:
  file.name:
    displayName: Horse Name
views:
  - type: table
    name: Table
    order:
      - file.name
      - better
      - post
      - odds
      - points
      - earnings
      - trainer
      - running_style
    sort:
      - property: file.name
        direction: ASC
      - property: running_style
        direction: ASC
    columnSize:
      note.points: 92
      note.post: 63
